# Secrets / credentials — never commit
keys/
*.json.key
dev.env
dev.env.local
.env
*.pem

# OS / editor noise
.DS_Store
*.swp
.idea/
.vscode/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage

# Build artifacts
dist/
build/

# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfplan
*.tfplan.binary
tfplan*

# Per-machine runtime cache (Cloud Run URLs etc.)
.fsi-state/
.fsi-state.json

# Node
node_modules/
infra/shared/terraform.tfvars

# Large binary fixtures — derived on-demand, not committed
# Pull with services/atomic/document-extractor/tests/fixtures/download.sh
# and scripts/demo_applications/build_pdfs.sh
services/atomic/document-extractor/tests/fixtures/*.pdf
scripts/demo_applications/_raw_pdfs/
scripts/demo_applications/BRW-*/files/*.pdf

# Local dev process / log noise
/tmp/dev*.log
ui/apps/pipeline-console/_diag.mjs
