{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@fsi-bank/components": ["./_vendor/components/src/index.ts"],
      "@fsi-bank/components/*": ["./_vendor/components/src/*"],
      "@fsi-bank/theme": ["./_vendor/theme/src/index.ts"],
      "@fsi-bank/theme/*": ["./_vendor/theme/src/*"]
    }
  },
  "include": ["next-env.d.ts", "app/**/*.ts", "app/**/*.tsx", "components/**/*.ts", "components/**/*.tsx", "lib/**/*.ts", "_vendor/**/*.ts", "_vendor/**/*.tsx", "_shared/**/*.ts"],
  "exclude": ["node_modules"]
}
