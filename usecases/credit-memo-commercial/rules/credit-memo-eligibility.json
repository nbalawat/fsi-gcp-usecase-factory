{
  "$schema": "https://gorules.io/schemas/rule.json",
  "contentType": "application/vnd.gorules.decision",
  "nodes": [
    {
      "id": "input",
      "name": "Request",
      "type": "inputNode",
      "position": {"x": 0, "y": 0},
      "content": {
        "fields": [
          {"id": "dscr_base", "name": "dscr_base", "dataType": "number"},
          {"id": "dscr_stressed", "name": "dscr_stressed", "dataType": "number"},
          {"id": "single_borrower_pct", "name": "single_borrower_pct", "dataType": "number"},
          {"id": "borrower_id", "name": "borrower_id", "dataType": "string"}
        ]
      }
    },
    {
      "id": "table",
      "name": "Credit Memo Eligibility",
      "type": "decisionTableNode",
      "position": {"x": 300, "y": 0},
      "content": {
        "hitPolicy": "first",
        "inputs": [
          {"id": "c1", "name": "dscr_base", "field": "dscr_base", "dataType": "number"},
          {"id": "c2", "name": "single_borrower_pct", "field": "single_borrower_pct", "dataType": "number"}
        ],
        "outputs": [
          {"id": "o1", "name": "decision", "field": "decision", "dataType": "string"},
          {"id": "o2", "name": "reason", "field": "reason", "dataType": "string"}
        ],
        "rules": [
          {
            "_id": "r1",
            "c1": "<= 1.0",
            "c2": "",
            "o1": "\"DECLINE\"",
            "o2": "\"DSCR base below minimum threshold of 1.0\""
          },
          {
            "_id": "r2",
            "c1": "",
            "c2": ">= 15",
            "o1": "\"REFER\"",
            "o2": "\"Single borrower concentration at or above 15 percent limit\""
          },
          {
            "_id": "r3",
            "c1": "> 1.0",
            "c2": "< 15",
            "o1": "\"APPROVE\"",
            "o2": "\"DSCR base adequate and concentration within limit\""
          }
        ]
      }
    },
    {
      "id": "output",
      "name": "Response",
      "type": "outputNode",
      "position": {"x": 600, "y": 0}
    }
  ],
  "edges": [
    {"id": "e1", "sourceId": "input", "targetId": "table"},
    {"id": "e2", "sourceId": "table", "targetId": "output"}
  ]
}
