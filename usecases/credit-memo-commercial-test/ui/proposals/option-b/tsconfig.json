{
  "extends": "../../../../../ui/tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "jsx": "preserve",
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@fsi-bank/components": [
        "../../../../../ui/packages/components/src/index.ts"
      ],
      "@fsi-bank/components/*": [
        "../../../../../ui/packages/components/src/*"
      ],
      "@fsi-bank/theme": ["../../../../../ui/packages/theme/src/index.ts"],
      "@/*": ["./*"]
    },
    "types": ["react", "react-dom", "node"]
  },
  "include": ["**/*.ts", "**/*.tsx", "../_shared/**/*.ts"],
  "exclude": ["node_modules"]
}
