{
  "$schema": "https://gorules.io/schemas/rule.json",
  "contentType": "application/vnd.gorules.decision",
  "nodes": [
    {
      "id": "input",
      "name": "Request",
      "type": "inputNode",
      "position": {"x": 0, "y": 0},
      "content": {
        "fields": [
          {"id": "proposed_amount", "name": "proposed_amount", "dataType": "number"},
          {"id": "existing_exposure_committed", "name": "existing_exposure_committed", "dataType": "number"},
          {"id": "tier1_capital", "name": "tier1_capital", "dataType": "number"}
        ]
      }
    },
    {
      "id": "fn",
      "name": "Single Borrower Limit Check",
      "type": "functionNode",
      "position": {"x": 300, "y": 0},
      "content": {
        "source": "export const handler = (input) => {\n  const total = input.proposed_amount + input.existing_exposure_committed;\n  const limit = input.tier1_capital * 0.15;\n  const headroom = limit - total;\n  return {\n    limit_status: total > limit ? 'breach' : (headroom < limit * 0.1 ? 'warning' : 'pass'),\n    headroom_dollars: headroom,\n    total_exposure: total,\n    limit_dollars: limit\n  };\n};"
      }
    },
    {
      "id": "output",
      "name": "Response",
      "type": "outputNode",
      "position": {"x": 600, "y": 0}
    }
  ],
  "edges": [
    {"id": "e1", "sourceId": "input", "targetId": "fn"},
    {"id": "e2", "sourceId": "fn", "targetId": "output"}
  ]
}
