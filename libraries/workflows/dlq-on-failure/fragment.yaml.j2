- dlq_publish_{{step_name}}:
    call: googleapis.pubsub.v1.projects.topics.publish
    args:
      topic: {{dlq_topic}}
      body:
        messages:
          - attributes:
              context_id: ${context_id}
              failed_step: "{{step_name}}"
              use_case: ${use_case}
            data: ${base64.encode(json.encode({
                "failed_step": "{{step_name}}",
                "error_code": {{error_var}}.code,
                "error_message": {{error_var}}.message,
                "error_tags": {{error_var}}.tags,
                "retry_count": default(map.get({{error_var}}, "retry_count"), 0),
                "original_payload": {{original_payload_var}},
                "context_id": context_id,
                "ts": sys.now()
              }))}
    retry:
      predicate: ${http.default_retry_predicate}
      max_retries: 5
      backoff:
        initial_delay: 2
        max_delay: 60
        multiplier: 2

- dlq_reraise_{{step_name}}:
    raise: ${{{error_var}}}
